/*
========================================================================================
    test_local profile
    Mevcut sistem kurulumunu kullanır — yeni conda env veya Docker image indirmez.
    Araç yolları bu makinedeki gerçek env'lere bağlıdır.
========================================================================================
*/

params {
    samplesheet      = "${projectDir}/assets/test_data/test_samplesheet.csv"
    outdir           = "${projectDir}/test_results"

    // Doğru veritabanı yolları
    kraken2_db       = "/home/analysis/databases_all/kraken2_db"
    virsorter2_db    = "/home/analysis/databases_all/virsorter2_db"
    checkv_db        = "/home/analysis/checkv_database/checkv-db-v1.5"
    blast_db         = null    // BLAST atla

    skip_virsorter   = false   // DB kuruldu
    skip_kraken2     = false

    // CheckV filtre — küçük test veri için daha düşük eşik
    min_completeness = 50
    min_contig_len   = 500

    // Kaynak limitleri
    max_cpus    = 14
    max_memory  = '14.GB'
    max_time    = '12.h'
}

// Her process için mevcut conda env yolunu kullan
process {
    withName: 'FASTQC' {
        conda = '/home/analysis/miniconda3'
        executor = 'local'
    }
    withName: 'FASTP' {
        conda = '/home/analysis/miniconda3'          // base: fastp sistem PATH'inde
        executor = 'local'
    }
    withName: 'KRAKEN2' {
        conda = '/home/analysis/miniconda3'          // base: kraken2 sistem PATH'inde
        executor = 'local'
    }
    withName: 'SPADES' {
        conda = '/home/analysis/miniconda3'          // base: spades.py sistem PATH'inde
        executor = 'local'
    }
    withName: 'VIRSORTER2' {
        conda = '/home/analysis/miniconda3/envs/vs2'
        executor = 'local'
    }
    withName: 'CHECKV' {
        conda = '/home/analysis/miniconda3/envs/checkv'
        executor = 'local'
    }
    withName: 'FILTER_CHECKV_CIRCULAR' {
        conda = '/home/analysis/miniconda3'          // sadece python3 gerekli
        executor = 'local'
    }
    withName: 'BACPHLIP' {
        conda = '/home/analysis/miniconda3/envs/bacphlip'
        executor = 'local'
    }
    withName: 'PHROKKA' {
        conda = '/home/analysis/miniconda3/envs/pharokka'
        executor = 'local'
    }
    withName: 'PROKKA' {
        conda = '/home/analysis/miniconda3'          // prokka base env'de
        executor = 'local'
    }
    withName: 'VCONTACT2' {
        conda = '/home/analysis/miniconda3/envs/vContact2'
        executor = 'local'
    }
    withName: 'VHULK' {
        conda = '/home/analysis/miniconda3/envs/vHULK'
        executor = 'local'
    }
    withName: 'MULTIQC' {
        conda = '/home/analysis/miniconda3/envs/nextflow'
        executor = 'local'
    }
    withName: 'SUMMARY_REPORT' {
        conda = '/home/analysis/miniconda3'          // sadece python3 gerekli
        executor = 'local'
    }
}

conda.enabled = true
docker.enabled = false
singularity.enabled = false
