/*
========================================================================================
    test_local profile
    Mevcut sistem kurulumunu kullanır — yeni conda env veya Docker image indirmez.
    Araç yolları bu makinedeki gerçek env'lere bağlıdır.
========================================================================================
*/

params {
    samplesheet      = "${projectDir}/assets/test_data/test_samplesheet.csv"
    outdir           = "${projectDir}/test_results"

    // Doğru veritabanı yolları
    kraken2_db       = "/home/analysis/databases_all/kraken2_db"
    virsorter2_db    = "/home/analysis/databases_all/virsorter2_db"
    checkv_db        = "/home/analysis/checkv_database/checkv-db-v1.5"
    blast_db         = null    // BLAST atla

    skip_virsorter   = true    // vs2 conda env kurulu değil; SPAdes → CheckV
    skip_kraken2     = false

    // CheckV filtre — küçük test veri için daha düşük eşik
    min_completeness = 50
    min_contig_len   = 500

    // Kaynak limitleri
    max_cpus    = 14
    max_memory  = '14.GB'
    max_time    = '12.h'
}

// Tüm adımlar tek phage_analysis conda env'inden çalışır.
// Kurulum: conda env create -f environment.yml
// Env mevcut değilse eski ayrı env'lere geri dön (yorum satırları).
def SINGLE_ENV = '/home/analysis/miniconda3/envs/phage_analysis'

process {
    withName: 'FASTQC'                 { conda = SINGLE_ENV; executor = 'local' }
    withName: 'FASTP'                  { conda = SINGLE_ENV; executor = 'local' }
    withName: 'KRAKEN2'                { conda = SINGLE_ENV; executor = 'local' }
    withName: 'SPADES'                 { conda = SINGLE_ENV; executor = 'local' }
    withName: 'VIRSORTER2'             { conda = SINGLE_ENV; executor = 'local' }
    withName: 'CHECKV'                 { conda = SINGLE_ENV; executor = 'local' }
    withName: 'FILTER_CHECKV_CIRCULAR' { conda = SINGLE_ENV; executor = 'local' }
    withName: 'BACPHLIP'               { conda = SINGLE_ENV; executor = 'local' }
    withName: 'PHROKKA'                { conda = SINGLE_ENV; executor = 'local' }
    withName: 'PROKKA'                 { conda = SINGLE_ENV; executor = 'local' }
    withName: 'VCONTACT2'              { conda = SINGLE_ENV; executor = 'local' }
    withName: 'VHULK'                  { conda = SINGLE_ENV; executor = 'local' }
    withName: 'BLAST'                  { conda = SINGLE_ENV; executor = 'local' }
    withName: 'MULTIQC'                { conda = SINGLE_ENV; executor = 'local' }
    withName: 'SUMMARY_REPORT'         { conda = SINGLE_ENV; executor = 'local' }
}

conda.enabled = true
docker.enabled = false
singularity.enabled = false
