/*
========================================================================================
    phage_analysis Nextflow Pipeline — Configuration
    https://github.com/cinnetcrash/phage_analysis
========================================================================================
*/

manifest {
    name            = 'phage_analysis'
    author          = 'cinnetcrash'
    homePage        = 'https://github.com/cinnetcrash/phage_analysis'
    description     = 'Bacteriophage discovery and characterization pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

// ── Varsayılan parametreler ───────────────────────────────────────────────────
params {
    // ── Girdi/çıktı ──────────────────────────────────────────────────────────
    samplesheet     = null
    outdir          = 'results'
    help            = false

    // ── Veritabanları (kullanıcı kendi yolunu girmeli) ───────────────────────
    kraken2_db      = null   // zorunlu (--skip_kraken2 kullanılmazsa)
    virsorter2_db   = null   // zorunlu (--skip_virsorter kullanılmazsa)
    checkv_db       = null   // zorunlu: --checkv_db /path/to/checkv_db
    blast_db        = null   // opsiyonel: --blast_db /path/to/nt  (boş bırakılırsa BLAST atlanır)
    vcontact2_db    = 'ProkaryoticViralRefSeq94-Merged'   // vContact2 dahili DB adı

    // ── Adım atlama seçenekleri ───────────────────────────────────────────────
    skip_virsorter  = false  // true: SPAdes → CheckV (VirSorter2 DB yoksa kullan)
    skip_kraken2    = false  // true: Kraken2 sınıflandırma adımını atla

    // ── Assembly / filtreleme ────────────────────────────────────────────────
    spades_mode     = 'auto' // 'auto' → versiyona göre --metaviral veya --meta seçer
                             // 'metaviral' → zorla --metaviral (SPAdes >= 3.15)
                             // 'meta'      → zorla --meta (eski sürümler)
    min_contig_len  = 1000   // SPAdes çıktısından minimum contig uzunluğu (bp)

    // ── CheckV circular filtre ───────────────────────────────────────────────
    // "Complete" kaliteli VE (completeness >= min_completeness AND DTR/ITR var)
    min_completeness = 90    // (%)

    // ── Kaynak limitleri ─────────────────────────────────────────────────────
    max_memory      = '128.GB'
    max_cpus        = 32
    max_time        = '72.h'
}

// ── Süreç varsayılanları ──────────────────────────────────────────────────────
process {
    cpus   = { check_max( 4                 , 'cpus'   ) }
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h * task.attempt , 'time'   ) }

    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2

    withName: 'SPADES' {
        cpus   = { check_max( params.max_cpus         , 'cpus'   ) }
        memory = { check_max( params.max_memory       , 'memory' ) }
        time   = { check_max( 24.h                    , 'time'   ) }
    }
    withName: 'VIRSORTER2' {
        cpus   = { check_max( params.max_cpus, 'cpus'   ) }
        memory = { check_max( params.max_memory, 'memory' ) }
        time   = { check_max( 12.h           , 'time'   ) }
    }
    withName: 'CHECKV' {
        cpus   = { check_max( params.max_cpus, 'cpus'   ) }
        memory = { check_max( params.max_memory, 'memory' ) }
    }
    withName: 'VCONTACT2' {
        cpus   = { check_max( params.max_cpus  , 'cpus'   ) }
        memory = { check_max( params.max_memory, 'memory' ) }
        time   = { check_max( 48.h             , 'time'   ) }
    }
    withName: 'PHROKKA' {
        cpus   = { check_max( params.max_cpus  , 'cpus'   ) }
        memory = { check_max( params.max_memory, 'memory' ) }
        time   = { check_max( 6.h              , 'time'   ) }
    }
    withName: 'BLAST' {
        cpus   = { check_max( params.max_cpus  , 'cpus'   ) }
        memory = { check_max( params.max_memory, 'memory' ) }
        time   = { check_max( 12.h             , 'time'   ) }
    }
}

// ── Profiller ────────────────────────────────────────────────────────────────
profiles {
    // ─── Conda (varsayılan) ──────────────────────────────────────────────────
    conda {
        conda.enabled    = true
        docker.enabled   = false
        singularity.enabled = false
        process {
            withName: 'FASTQC'               { conda = 'bioconda::fastqc=0.12.1' }
            withName: 'KRAKEN2'              { conda = 'bioconda::kraken2=2.1.3' }
            withName: 'SPADES'               { conda = 'bioconda::spades=4.0.0' }
            withName: 'VIRSORTER2'           { conda = 'bioconda::virsorter2=2.2.4' }
            withName: 'CHECKV'               { conda = 'bioconda::checkv=1.0.1' }
            withName: 'FILTER_CHECKV_CIRCULAR' { conda = 'conda-forge::python=3.10' }
            withName: 'BACPHLIP'             { conda = 'conda-forge::bacphlip=0.9.6' }
            withName: 'PHROKKA'              { conda = 'bioconda::pharokka=1.7.3' }
            withName: 'PROKKA'               { conda = 'bioconda::prokka=1.14.6' }
            withName: 'VCONTACT2'            { conda = 'bioconda::vcontact2=0.9.19' }
            withName: 'VHULK'               { conda = 'bioconda::vhulk=1.0.0' }
            withName: 'BLAST'                { conda = 'bioconda::blast=2.15.0' }
            withName: 'MULTIQC'              { conda = 'bioconda::multiqc=1.21' }
        }
    }

    // ─── Docker ──────────────────────────────────────────────────────────────
    docker {
        docker.enabled   = true
        conda.enabled    = false
        singularity.enabled = false
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            withName: 'FASTQC'    { container = 'staphb/fastqc:0.12.1' }
            withName: 'KRAKEN2'   { container = 'staphb/kraken2:2.1.3' }
            withName: 'SPADES'    { container = 'staphb/spades:4.0.0' }
            withName: 'PROKKA'    { container = 'staphb/prokka:1.14.6' }
            withName: 'MULTIQC'   { container = 'staphb/multiqc:1.19' }
        }
    }

    // ─── Singularity ─────────────────────────────────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        conda.enabled          = false
        docker.enabled         = false
    }

    // ─── SLURM / HPC ─────────────────────────────────────────────────────────
    slurm {
        process.executor = 'slurm'
        process.queue    = 'long'
        conda.enabled    = true
    }

    // ─── Test (küçük veri, pipeline doğrulama) ───────────────────────────────
    test {
        params {
            samplesheet      = "${projectDir}/assets/test_samplesheet.csv"
            outdir           = 'test_results'
            min_contig_len   = 500
            min_completeness = 50
        }
    }

    // ─── test_local: mevcut sistem kurulumunu kullan (DB + env yeniden indir) ─
    test_local {
        includeConfig 'conf/test_local.config'
    }
}

// ── Raporlama ────────────────────────────────────────────────────────────────
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.tsv"
    overwrite = true
}
dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}

// ── Yardımcı: kaynak sınır kontrol fonksiyonu ─────────────────────────────────
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min( obj, params.max_cpus as int ) }
        catch (all) { return obj }
    }
}
